# =============================================================================
# VidLab Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.

# ── Server ──────────────────────────────────────────────────────────────────
# Port the Flask server listens on.
PORT=8000

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call /api/* routes.
# In production, set this to your deployed frontend URL(s).
# Example: https://vidlab.vercel.app,https://vidlab.pages.dev
ALLOWED_ORIGINS=

# ── YouTube Downloader ──────────────────────────────────────────────────────
# Directory where yt-dlp downloads are stored (default: backend/downloads).
VIDLAB_DOWNLOAD_DIR=

# Max seconds allowed for a single download (default: 600 = 10 min).
VIDLAB_DOWNLOAD_TIMEOUT=600

# ── File Uploads ────────────────────────────────────────────────────────────
# Max upload size in bytes (default: 200MB).
# MAX_CONTENT_LENGTH=209715200

# ── Feature Toggles ─────────────────────────────────────────────────────────
# Set to "0" or "false" to disable AI-powered scene analysis.
# This saves ~1GB RAM. Scene route will return an error message.
# ENABLE_SCENE_ANALYSIS=1

# Set to "0" or "false" to disable Whisper transcription.
# Saves ~150MB RAM.
# ENABLE_TRANSCRIPTION=1