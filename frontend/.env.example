# Build-time URL of the deployed Flask backend (e.g. https://vidlab-backend.example.com).
# When unset, the app uses same-origin /api which is proxied to localhost:8000 in dev.
VITE_API_BASE_URL=

# Optional dev-only override for the Vite proxy target. Defaults to http://localhost:8000.
VITE_DEV_API_PROXY=
