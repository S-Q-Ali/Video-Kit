{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm -C .. --filter @workspace/vidlab run build",
  "installCommand": "pnpm -C .. install --frozen-lockfile",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
